# Database
DATABASE_URL=postgresql://user:password@postgres:5432/inventory_db

# App
DEBUG=0
SECRET_KEY=change-this-secret-key
SESSION_MAX_AGE_SECONDS=43200
APP_BASE_URL=http://localhost:8000

# SMTP (for password reset)
# Важно: укажите РЕАЛЬНЫЙ хост вашей почты. smtp.example.com из шаблона не существует в DNS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Реальный Gmail и пароль приложения (16 символов). Без кавычек пробелы ломают строку —
# либо одной строкой без пробелов, либо в кавычках: SMTP_PASSWORD="xxxx xxxx xxxx xxxx"
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# Для Gmail: тот же адрес, что и SMTP_USERNAME
SMTP_SENDER=you@gmail.com
SMTP_ACCOUNT_ACTIVATION_ADMIN_EMAIL=...
# 587: STARTTLS
SMTP_USE_TLS=1
# 465: implicit SSL — выставьте SMTP_USE_SSL=1, SMTP_USE_TLS=0, SMTP_PORT=465
SMTP_USE_SSL=0
#
# Gmail (smtp.gmail.com): нужен «пароль приложения», не обычный пароль аккаунта:
# https://myaccount.google.com/apppasswords
# Пример: SMTP_PORT=587, SMTP_USE_TLS=1, SMTP_USE_SSL=0
# Временная отладка без почты: DEBUG=1 — при сбое SMTP ссылка сброса пишется в лог uvicorn.
